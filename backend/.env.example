# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Frontend origin(s) for CORS. Comma-separate to allow multiple origins
# (e.g. production + Vercel preview deployments).
# In production: FRONTEND_URL=https://your-app.vercel.app,https://app.example.com
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://yt_user:yt_password@localhost:5432/yt_transcripts

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace-me-with-a-long-random-string-32-chars-min
JWT_COOKIE_NAME=yt_session
JWT_EXPIRES_IN=7d

# Stub flags (true for local dev, false to use real services)
STUB_STRIPE=true
STUB_WHISPER=true
STUB_PROXY=true
STUB_TRANSLATION=true

# Stripe (only used when STUB_STRIPE=false)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=

# OpenAI Whisper (only used when STUB_WHISPER=false)
OPENAI_API_KEY=

# Residential proxy (only used when STUB_PROXY=false)
PROXY_URL=
# Example: http://username:password@proxy.provider.com:8080

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MIN=100
