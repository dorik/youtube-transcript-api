# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Frontend origin(s) for CORS. Comma-separate to allow multiple origins
# (e.g. production + Vercel preview deployments).
# In production: FRONTEND_URL=https://your-app.vercel.app,https://app.example.com
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://yt_user:yt_password@localhost:5432/yt_transcripts

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace-me-with-a-long-random-string-32-chars-min
JWT_COOKIE_NAME=yt_session
JWT_EXPIRES_IN=7d

# Stripe — required for paid plans / checkout / webhooks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=

# OpenAI — required for Whisper transcription (paid plans) and (optionally)
# higher-quality translation. Without it translation falls back to the free
# google-translate-api-x path.
OPENAI_API_KEY=

# Outbound proxy for YouTube requests.
# Required in production — Render's egress IPs get 429'd by YouTube.
# Webshare datacenter (recommended start, ~$10/mo for 10 rotating IPs):
#   PROXY_URL=http://USER-rotate:PASS@p.webshare.io:80
# PacketStream residential ($1/GB, slower but harder to block):
#   PROXY_URL=http://USER:PASS@proxy.packetstream.io:31112
PROXY_URL=

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MIN=100
